**/.axiom/cache/
**/.axiom/data/
**/.axiom/logs/
**/.axiom/models/

!.axiom/**/.gitkeep
!**/axiom.toml

# Note: vendors/ is INTENTIONALLY tracked per CLAUDE.md "Vendor forks" section.
# The vendors/polymarket-client-sdk fork carries the BROADCAST_CAPACITY: 1024 → 8192
# patch. Only nested vendor caches (e.g., target/) should be ignored, not the
# vendor source itself.

# Legacy agent runtime (remove once migrated)
.agent/

# Databases (live in .axiom/data/ or .artifacts/data/)
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# config files
**/*.config.*
**/settings.local.*

# Bot TOML migration backups (v0.3.1-dev.6 — bots consolidated into settings.json)
.axiom/config/bots/*.toml.bak

!**/default.config.*


